{
  "name": "studio-admin",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "ts-node -P tsconfig.scripts.json src/scripts/apply-sql-migrations.ts",
    "db:migrate:drizzle": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:init": "node scripts/db-command.js migrations/001_init.sql",
    "db:seed": "node scripts/db-command.js migrations/002_seed.sql",
    "db:setup": "npm run db:init && npm run db:seed && npm run db:import && npm run db:rankings && npm run db:view",
    "db:import": "node scripts/import-data.js",
    "db:view": "node scripts/db-command.js migrations/004_create_standings_page_rows_view.sql",
    "db:rankings": "node scripts/db-command.js migrations/003_generate_rankings.sql",
    "db:snapshots": "node scripts/db-command.js migrations/005_update_rank_delta.sql",
    "generate:presets": "ts-node -P tsconfig.scripts.json src/scripts/generate-theme-presets.ts"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": ["biome check --write --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@fullcalendar/react": "^7.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-geo": "^3.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "simple-icons": "^16.24.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "temporal-polyfill": "^1.0.1",
    "topojson-client": "^3.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.1.5",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/autoledger.git"
  },
  "homepage": "https://github.com/your-username/autoledger"
}
